# 使用官方 npm 源
registry=https://registry.npmjs.org/

# @nut-tree 作用域包使用淘宝镜像（因为官方源可能未同步）
# 注意：只有 @nut-tree/* 包会使用此镜像，其他包（包括 electron）都使用官方源
@nut-tree:registry=https://registry.npmmirror.com

# Electron 二进制文件使用官方源（不使用淘宝镜像，因为淘宝镜像的 electron 有问题）
electron_mirror=https://github.com/electron/electron/releases/download/

# 配置 pnpm 使用 hoisted 模式，确保依赖能被正确打包
node-linker=hoisted


