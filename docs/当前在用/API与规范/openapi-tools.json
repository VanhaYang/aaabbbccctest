{
  "openapi": "3.0.3",
  "info": {
    "title": "Electron Screenshot API (Tools)",
    "description": "桌面工具 API：提供工作区文件读写、精准编辑、命令执行、截屏与鼠标控制；以及浏览器工具（browser_navigate、browser_snapshot、browser_screenshot、browser_act），在项目内通过 Playwright + 本机 Chrome 实现。每个能力对应独立接口，可选 Bearer 鉴权。",
    "version": "2.0.4",
    "x-app-version": "1.5.1"
  },
  "servers": [
    {
      "url": "http://192.168.24.26:28473",
      "description": "API 服务器"
    }
  ],
  "paths": {
    "/tools/list": {
      "get": {
        "summary": "列出已注册工具",
        "description": "返回当前可用的工具 id 列表，用于发现本机支持的桌面能力。",
        "operationId": "listTools",
        "tags": [
          "Tools"
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "toolIds": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "工具 id 列表：read, write, edit, exec, screenshot, mouse_move, mouse_click, apply_patch, browser_navigate, browser_snapshot, browser_screenshot, browser_act（后四者为项目内 Playwright 浏览器）"
                        }
                      }
                    },
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string"
                    },
                    "success": {
                      "type": "boolean",
                      "example": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tools/execute": {
      "post": {
        "summary": "执行工具（统一入口）",
        "description": "根据指定工具 id 与传入参数执行桌面操作。桌面工具：read、write、edit、exec、screenshot、mouse_move、mouse_click、apply_patch。浏览器工具（项目内 Playwright + 本机 Chrome）：browser_navigate、browser_snapshot、browser_screenshot、browser_act。",
        "operationId": "executeTool",
        "tags": [
          "Tools"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ToolExecuteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "执行成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "description": "工具返回结果，依 toolId 不同而不同"
                    },
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string"
                    },
                    "success": {
                      "type": "boolean",
                      "example": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "参数错误或执行失败",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "无权限",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "未知 toolId",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "执行异常",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
