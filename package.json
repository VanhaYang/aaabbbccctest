{
  "name": "electron-screenshot",
  "version": "1.5.1",
  "description": "A screenshot tool built with Electron, React and TypeScript",
  "main": "out/main/index.js",
  "author": "Your Name",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "compile": "electron-vite build && node scripts/compile-all.js",
    "compile:linux": "electron-vite build && electron-builder --linux --publish never",
    "compile:mac": "electron-vite build && electron-builder --mac --publish never",
    "build:release": "electron-vite build && electron-builder --publish never",
    "postinstall": "electron-builder install-app-deps && npm run ensure-ripgrep",
    "ensure-ripgrep": "node -e \"const fs=require('fs'),p=require('path');const binDir=p.join('node_modules','@vscode','ripgrep','bin');const bin=p.join(binDir,process.platform==='win32'?'rg.exe':'rg');if(!fs.existsSync(bin)){if(fs.existsSync(binDir))try{fs.rmSync(binDir,{recursive:true});}catch(e){}const c=require('child_process');c.spawnSync('node',[p.join('node_modules','@vscode','ripgrep','lib','postinstall.js')],{stdio:'inherit'});}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "vitest run --config vitest.config.api.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@nut-tree/nut-js": "^4.0.0",
    "@vscode/ripgrep": "^1.17.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.9",
    "execa": "^8.0.1",
    "iconv-lite": "^0.7.2",
    "marked": "^16.4.2",
    "nanoid": "^5.1.6",
    "playwright-core": "^1.58.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "core-util-is": "^1.0.3",
    "electron": "37.0.0",
    "electron-builder": "^25.0.0",
    "electron-builder-squirrel-windows": "^25.0.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^4.0.18"
  }
}
